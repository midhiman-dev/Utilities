<Window x:Class="MermaidPng.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Mermaid to PNG Converter" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" MinWidth="300"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="1.5*" MinWidth="400"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Editor and Controls -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <Button Content="Open File" Command="{Binding OpenFileCommand}"/>
                <Button Content="Export PNG" Command="{Binding ExportPngCommand}"/>
                <Button Content="Copy Error" Command="{Binding CopyErrorCommand}" 
                        IsEnabled="{Binding HasError}"/>
            </StackPanel>

            <!-- Editor -->
            <TextBox Grid.Row="1" 
                     Text="{Binding MermaidCode, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="13"
                     Padding="5"/>

            <!-- Render Options -->
            <GroupBox Grid.Row="2" Header="Render Options" Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Scale -->
                    <Label Grid.Row="0" Grid.Column="0" Content="Scale:"/>
                    <ComboBox Grid.Row="0" Grid.Column="1"
                              ItemsSource="{Binding ScaleOptions}"
                              SelectedItem="{Binding SelectedScale}"/>

                    <!-- Theme -->
                    <Label Grid.Row="0" Grid.Column="2" Content="Theme:"/>
                    <ComboBox Grid.Row="0" Grid.Column="3"
                              ItemsSource="{Binding ThemeOptions}"
                              SelectedItem="{Binding SelectedTheme}"/>

                    <!-- Background -->
                    <Label Grid.Row="1" Grid.Column="0" Content="Background:"/>
                    <ComboBox Grid.Row="1" Grid.Column="1"
                              ItemsSource="{Binding BackgroundOptions}"
                              SelectedItem="{Binding SelectedBackground}"/>

                    <!-- Custom Color Picker -->
                    <Label Grid.Row="1" Grid.Column="2" Content="Color:"
                           Visibility="{Binding IsCustomColorVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBox Grid.Row="1" Grid.Column="3"
                             Text="{Binding CustomBackgroundColor, UpdateSourceTrigger=PropertyChanged}"
                             Visibility="{Binding IsCustomColorVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                             ToolTip="Enter hex color, e.g., #FFFFFF"/>

                    <!-- Max Dimensions -->
                    <Label Grid.Row="2" Grid.Column="0" Content="Max Width:"/>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Text="{Binding MaxWidth, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Grid.Row="2" Grid.Column="2" Content="Max Height:"/>
                    <TextBox Grid.Row="2" Grid.Column="3"
                             Text="{Binding MaxHeight, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </GroupBox>

            <!-- Status Bar -->
            <Border Grid.Row="3" Background="#F0F0F0" BorderBrush="#CCCCCC" 
                    BorderThickness="0,1,0,0" Padding="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" 
                               Text="{Binding StatusMessage}" 
                               TextWrapping="Wrap"
                               Foreground="{Binding StatusForeground}"/>
                    <Button Grid.Column="1" 
                            Content="Cancel" 
                            Command="{Binding CancelRenderCommand}"
                            Visibility="{Binding IsRendering, Converter={StaticResource BoolToVisibilityConverter}}"
                            Padding="8,3"
                            Margin="5,0,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" 
                      Background="#CCCCCC"/>

        <!-- Right Panel: Preview -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Preview" FontSize="14" FontWeight="Bold" 
                       Margin="5" HorizontalAlignment="Center"/>

            <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" Margin="5">
                <wv2:WebView2 x:Name="PreviewWebView"/>
            </Border>
        </Grid>
    </Grid>
</Window>
